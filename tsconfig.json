{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "$lib/*": ["./frontend/src/lib/*"]
    }
  },
  "include": ["frontend/src/**/*.ts", "frontend/src/**/*.svelte"]
}
